# ============================================================
# DELTA AI Agent — Variabili d'ambiente
# ============================================================
# Copia questo file come .env nella stessa directory:
#
#   cp .env.example .env
#   nano .env
#
# Poi modifica i valori con le tue credenziali reali.
# Il file .env NON deve essere condiviso né committato su git.
# ============================================================

# ── Token del bot Telegram @DELTAPLANO_bot ────────────────────
# Ottieni il token da @BotFather su Telegram con il comando /newbot
# o /mybots se il bot esiste già.
DELTA_TELEGRAM_TOKEN=inserisci_qui_il_token_del_bot

# ── ElevenLabs TTS (opzionale, voce premium DELTAPLANO) ──────
# Se configurato, il bot usa ElevenLabs come provider TTS primario.
# In assenza della chiave, resta attivo il fallback edge-tts.
ELEVENLABS_API_KEY=inserisci_qui_la_tua_api_key_elevenlabs
# Opzionale: voice ID personalizzato. Se lasciato vuoto, il bot usa
# il voice ID di default definito nella configurazione Telegram.
# ELEVENLABS_VOICE_ID=voce_personalizzata_opzionale

# ── (Opzionale) Password admin DELTA ─────────────────────────
# Se non impostata viene generata automaticamente al primo avvio.
# DELTA_ADMIN_PASSWORD=cambiami

# ── NASA DeltaPlant pipeline ────────────────────────────────
EARTHDATA_USERNAME=deltaplant
EARTHDATA_PASSWORD=inserisci_qui_la_password_earthdata
EARTHDATA_BASE_URL=https://urs.earthdata.nasa.gov
COPERNICUS_USERNAME=inserisci_qui_l_utente_copernicus
COPERNICUS_PASSWORD=inserisci_qui_la_password_copernicus
COPERNICUS_BASE_URL=https://dataspace.copernicus.eu
NASA_POWER_BASE_URL=https://power.larc.nasa.gov/api/temporal/daily/point
SECRET_KEY=inserisci_qui_un_secret_key_lungo_e_random
JWT_ALGORITHM=HS256
PDF_TEMP_DIR=/tmp/deltaplant
