        }
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "DELTA: ATTIVITA' DIVULGATIVE",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "tools/prepare_dissemination_artifacts.py"
