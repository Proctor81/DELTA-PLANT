{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "DELTA: Train Keras Classifier",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "ai/train_keras_classifier.py",
        "--dataset", "datasets/training",
        "--output", "models",
        "--resume"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "DELTA: Pipeline AI Resume + Convert + Preflight",
      "dependsOrder": "sequence",
      "dependsOn": [
        "DELTA: Train Keras Classifier",
        "DELTA: Convert to TFLite INT8",
        "DELTA: Preflight Only"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "DELTA: Export EfficientFormer TFLite",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "ai/export_efficientformer_tflite.py",
        "--dataset-root", "datasets/training",
        "--output-dir", "models",
        "--mode", "all",
        "--quantization", "both"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "DELTA: Benchmark Vision Backends",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "tools/benchmark_vision_models.py",
        "--model-keys", "generale", "efficientformer",
        "--image", "models/validation_sample.jpg",
        "--runs", "100",
        "--warmup", "10"
      ],
      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
        }
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "DELTA: Evaluate Vision Backends",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "ai/evaluate_vision_backends.py",
