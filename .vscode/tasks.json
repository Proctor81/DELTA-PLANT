      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "DELTA: Preflight + Avvia Sistema",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "main.py",
        "--preflight",
        "--enable-api",
        "--enable-telegram",
        "--daemon"
      ],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "shared"
      },
      "problemMatcher": []
