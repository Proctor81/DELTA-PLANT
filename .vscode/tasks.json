      "options": {
        "cwd": "${workspaceFolder}",
        "env": {
          "PYTHONPATH": "${workspaceFolder}:${env:PYTHONPATH}"
        }
      },
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "problemMatcher": []
    },
    {
      "label": "DELTA: Pipeline EfficientFormer Export + Benchmark + Evaluate",
      "dependsOrder": "sequence",
      "dependsOn": [
        "DELTA: Export EfficientFormer TFLite",
        "DELTA: Benchmark Vision Backends",
        "DELTA: Evaluate Vision Backends"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "DELTA: Pipeline X",
      "type": "shell",
      "command": "${workspaceFolder}/.venv/bin/python",
      "args": [
        "tools/pipeline_x.py",
